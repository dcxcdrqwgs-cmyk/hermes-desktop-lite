{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hermes Desktop Lite",
  "version": "0.1.0",
  "identifier": "com.hermes.desktop.lite",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "xattr -cr dist 2>/dev/null; npm run dev",
    "beforeBuildCommand": "xattr -cr dist 2>/dev/null; npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Hermes Desktop Lite",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src * 'self' data: blob: filesystem:; script-src * 'self' 'unsafe-inline' 'unsafe-eval'; connect-src * 'self' http://127.0.0.1:8642 http://localhost:5173; style-src * 'self' 'unsafe-inline'; img-src * data: blob: filesystem:; font-src * data: blob: filesystem:; worker-src *; frame-src *;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "files": {
        "app": "../dist"
      }
    }
  }
}
